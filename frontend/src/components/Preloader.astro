---
/* src/components/Preloader.astro */
---

<div id="preloader" class="preloader-overlay">
  <div class="preloader-spinner"></div>
</div>

<script>
  function initPreloader() {
    const preloader = document.getElementById("preloader");
    if (!preloader) return;

    // 關閉 Preloader 的統一函式
    const hidePreloader = () => {
      if (preloader.classList.contains("is-hidden")) return;
      
      preloader.classList.add("is-hidden");
      
      // 動畫結束後從 layout 中點擊穿透 & 徹底隱藏
      setTimeout(() => {
        preloader.style.display = "none";
      }, 500);
    };

    // 🎯 1. 容錯機制：不論圖片成功或失敗，最多只等 1 秒（1000ms），時間到強制關閉 Preloader
    const forceHideTimeout = setTimeout(() => {
      console.warn("[Preloader] Timeout reached. Forcing preloader to hide.");
      hidePreloader();
    }, 1000);

    // 🎯 2. 安全監聽：頁面資源 Ready 就立刻關閉
    if (document.readyState === "complete") {
      clearTimeout(forceHideTimeout);
      hidePreloader();
    } else {
      window.addEventListener(
        "load",
        () => {
          clearTimeout(forceHideTimeout);
          hidePreloader();
        },
        { once: true }
      );
    }
  }

  // 🎯 3. 支援 Astro ClientRouter (View Transitions)
  initPreloader();
  document.addEventListener("astro:page-load", initPreloader);
  document.addEventListener("astro:after-swap", initPreloader);
</script>

<style>
  .preloader-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: var(--color-bg, #ffffff);
    z-index: 9999;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: opacity 0.4s ease, visibility 0.4s ease;
    pointer-events: auto;
  }

  /* 🎯 淡出樣式：關鍵在 pointer-events: none */
  .preloader-overlay.is-hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none !important;
  }
</style>
---
/* src/components/Preloader.astro */
---

<div id="preloader" class="preloader-overlay">
  <div class="preloader-spinner"></div>
</div>

<script>
  function setupPreloader() {
    const preloader = document.getElementById("preloader");
    if (!preloader) return;

    const hide = () => {
      preloader.classList.add("is-hidden");
      setTimeout(() => {
        preloader.style.display = "none";
      }, 400);
    };

    // 🎯 超時防護：不論圖片有沒有破圖，最長只等 800ms 強制關閉 Preloader
    const timer = setTimeout(hide, 800);

    if (document.readyState === "complete") {
      clearTimeout(timer);
      hide();
    } else {
      window.addEventListener("load", () => {
        clearTimeout(timer);
        hide();
      }, { once: true });
    }
  }

  // 執行並綁定 Astro 生命週期
  setupPreloader();
  document.addEventListener("astro:page-load", setupPreloader);
</script>

<style>
  .preloader-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: var(--color-bg, #ffffff);
    z-index: 9999;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  /* 🎯 關鍵：隱藏後強制解除所有阻擋 */
  .preloader-overlay.is-hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none !important;
  }
</style>
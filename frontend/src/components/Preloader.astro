---
/* src/components/Preloader.astro */
---

<div id="preloader" class="preloader-overlay">
  <div class="preloader-spinner"></div>
</div>

<script>
  function setupPreloader() {
    const preloader = document.getElementById("preloader");
    if (!preloader) return;

    const hidePreloader = () => {
      if (preloader.classList.contains("is-hidden")) return;
      preloader.classList.add("is-hidden");
      setTimeout(() => {
        preloader.style.display = "none";
      }, 500);
    };

    // 🎯 1 秒超時強制關閉防爆，避免圖片 404 時卡住畫面
    const forceHideTimer = setTimeout(hidePreloader, 1000);

    if (document.readyState === "complete") {
      clearTimeout(forceHideTimer);
      hidePreloader();
    } else {
      window.addEventListener("load", () => {
        clearTimeout(forceHideTimer);
        hidePreloader();
      }, { once: true });
    }
  }

  setupPreloader();
  document.addEventListener("astro:page-load", setupPreloader);
  document.addEventListener("astro:after-swap", setupPreloader);
</script>

<style>
  .preloader-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: var(--color-bg, #ffffff);
    z-index: 9999;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: opacity 0.4s ease, visibility 0.4s ease;
    pointer-events: auto;
  }

  .preloader-overlay.is-hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none !important;
  }
</style>
---
import Separator from "../components/Separator.astro";
import TextSlider from "../components/TextSlider.astro";

const currentPath = Astro.url.pathname;

const routes = {
	"/": "Projects",
	"/about/": "About",
	"/contact/": "Contact",
};

const activeRoute = routes[currentPath] || null;
---

<header>
	<h1 class="logo-group">
		<a href="/">
			<TextSlider content="Chen-Pei Jyuan" />
		</a>
	</h1>

	<span class="role">
		<TextSlider content="Brand & Visual Designer" />
	</span>

	<ul>
		<li>
			<a
				href="/"
				class={activeRoute === "Projects" ? "current" : ""}
				data-astro-prefetch
			>
				<TextSlider content="Projects" />
			</a>
		</li>

		<li>
			<a
				href="/about/"
				class={activeRoute === "About" ? "current" : ""}
				data-astro-prefetch
			>
				<TextSlider content="About" />
			</a>
		</li>

		<li>
			<a
				href="/contact/"
				class={activeRoute === "Contact" ? "current" : ""}
				data-astro-prefetch
			>
				<TextSlider content="Contact" />
			</a>
		</li>
	</ul>
</header>

<Separator />

<style>
	header {
		position: relative;
		display: grid;
		grid-template-columns: auto auto 1fr;
		align-items: flex-end;

		column-gap: 1.5rem;
		row-gap: 1rem;

		padding: 1.75rem 0;

		z-index: 3;
	}

	h1 {
		margin: 0;
		font-size: 1.25rem;
		font-weight: 700;
		line-height: 1;
		white-space: nowrap;
	}

	/* 🎯 獨立設定名字的連結樣式，確保這裡絕對沒有底線效果 */
	.logo-group a {
		text-decoration: none;
		color: #000000;
		position: relative;
		padding-bottom: 0.65rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		pointer-events: auto !important; /* 確保名字永遠可以點擊回首頁 */
	}

	/* 🎯 確保名字下面絕對不會出現 ::after 的底線 */
	.logo-group a::after {
		display: none !important;
	}

	.role {
		font-size: 1rem;
		font-weight: 400;
		opacity: 0.45;
		line-height: 1;
		white-space: nowrap;
		padding-bottom: 0.65rem; /* 讓職稱與名字在同一水平線上對齊 */
	}

	ul {
		grid-column: 3;
		justify-self: end;

		display: flex;
		align-items: center;
		gap: 2rem;

		margin: 0;
		padding: 0;

		list-style: none;

		font-size: 1.25rem;
		font-weight: 700;
	}

	ul a {
		position: relative;
		text-decoration: none;
		color: #000000;
		padding-bottom: 0.65rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}

	/* 🎯 只有右側選單（ul 內的 a.current）才會有這條 4px 黑色厚底線 */
	ul a.current::after {
		content: "";
		position: absolute;
		left: 0;
		bottom: -2px;
		width: 100%;
		height: 4px;
		background-color: #000000;
	}

	/* 只有選單選中的項目會被鎖死點擊 */
	ul a.current {
		pointer-events: none;
	}

	/* 📱 手機版響應式調整 */
	@media (max-width: 768px) {
		header {
			grid-template-columns: auto 1fr;
			column-gap: 0.75rem;
			row-gap: 1.2rem;
			padding: 1.25rem 0;
		}

		ul {
			grid-column: 1 / -1;
			justify-self: start;
			gap: 1.5rem;
			font-size: 1.1rem;
		}

		h1 {
			font-size: 1.15rem;
		}

		.role {
			font-size: 0.9rem;
		}
	}
</style>
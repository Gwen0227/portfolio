---
import TextSlider from "../components/TextSlider.astro";

const currentPath = Astro.url.pathname;
const normalizedPath = currentPath.replace(/\/$/, "") || "/";

let currentTab = "Projects";
if (normalizedPath === "/about") {
	currentTab = "About";
} else if (normalizedPath === "/contact") {
	currentTab = "Contact";
}
---

<header>
	<div class="header-main">
		<!-- 品牌名稱與職稱 -->
		<div class="brand-group">
			<h1 class="logo-group">
				<a href="/">
					<TextSlider content="Chen-Pei Jyuan" />
				</a>
			</h1>

			<span class="role">
				<TextSlider content="Brand & Visual Designer" />
			</span>
		</div>

		<!-- 導覽選單（Projects / About / Contact） -->
		<ul class="nav-menu">
			<li>
				<a href="/" class={currentTab === "Projects" ? "current" : ""} data-astro-prefetch>
					<TextSlider content="Projects" />
				</a>
			</li>

			<li>
				<a href="/about" class={currentTab === "About" ? "current" : ""} data-astro-prefetch>
					<TextSlider content="About" />
				</a>
			</li>

			<li>
				<a href="/contact" class={currentTab === "Contact" ? "current" : ""} data-astro-prefetch>
					<TextSlider content="Contact" />
				</a>
			</li>
		</ul>
	</div>
</header>

<style>
	header {
		position: relative;
		width: 100%;
		z-index: 3;
	}

	/* 🎯 使用 flex + wrap 允許自動換行 */
	.header-main {
		display: flex;
		flex-wrap: wrap; /* 空間不夠時自動換行 */
		justify-content: space-between;
		align-items: flex-end;
		gap: 1.25rem 1.5rem; /* 上下左右間距 */
		padding: 1.25rem 0;
	}

	.brand-group {
		display: flex;
		align-items: flex-end;
		gap: 1.5rem;
		flex-wrap: wrap; /* 名字跟職稱不夠寬時也能換行 */
	}

	h1 {
		margin: 0;
		font-size: 1.2rem;
		font-weight: 600;
		line-height: 1;
		white-space: nowrap;
	}

	.logo-group a {
		text-decoration: none;
		color: #000000;
		position: relative;
		padding-bottom: 0.2rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}

	.logo-group a::after {
		display: none !important;
	}

	.role {
		font-size: 0.9rem;
		font-weight: 400;
		opacity: 0.45;
		line-height: 1;
		white-space: nowrap;
		padding-bottom: 0.2rem;
	}

	.nav-menu {
		display: flex;
		align-items: center;
		gap: 2rem;
		margin: 0;
		padding: 0;
		list-style: none;
		font-size: 0.9rem;
		font-weight: 600;
		/* 當視窗縮窄折行時，確保選單滿版或自動對齊 */
		flex-wrap: wrap;
	}

	.nav-menu a {
		position: relative;
		text-decoration: none;
		color: #000000;
		padding-bottom: 0.3rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}

	/* 4px 黑色厚底線 */
	.nav-menu a.current::after {
		content: "";
		position: absolute;
		left: 0;
		bottom: -2px;
		width: 100%;
		height: 4px;
		background-color: #000000;
	}

	.nav-menu a.current {
		pointer-events: none;
	}

	/* 📱 當視窗變窄或手機時的優化 */
	@media (max-width: 768px) {
		.header-main {
			padding: 1rem 0;
		}

		.brand-group {
			gap: 0.75rem;
		}

		.nav-menu {
			width: 100%; /* 折行後佔滿整行 */
			gap: 1.5rem;
			font-size: 0.95rem;
			margin-top: 0.25rem;
		}

		h1 {
			font-size: 1.1rem;
		}

		.role {
			font-size: 0.85rem;
		}
	}
</style>
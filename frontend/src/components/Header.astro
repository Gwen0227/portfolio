---
import Separator from "../components/Separator.astro";
import TextSlider from "../components/TextSlider.astro";

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const routes = {
	[base]: "Projects",
	[`${base}about/`]: "About",
	[`${base}contact/`]: "Contact",
};

const activeRoute = routes[currentPath] || null;
---

<header>
	<h1 class="logo-group">
		<a href={base}>
			<TextSlider content="Chen-Pei Jyuan" />
		</a>
	</h1>

	<span class="role">
		<TextSlider content="Brand & Visual Designer" />
	</span>

	<ul>
		<li>
			<a
				href={base}
				class={activeRoute === "Projects" ? "current" : ""}
				data-astro-prefetch
			>
				<TextSlider content="Projects" />
			</a>
		</li>

		<li>
			<a
				href={`${base}about/`}
				class={activeRoute === "About" ? "current" : ""}
				data-astro-prefetch
			>
				<TextSlider content="About" />
			</a>
		</li>

		<li>
			<a
				href={`${base}contact/`}
				class={activeRoute === "Contact" ? "current" : ""}
				data-astro-prefetch
			>
				<TextSlider content="Contact" />
			</a>
		</li>
	</ul>
</header>

<style>
	header {
		position: relative;
		display: grid;
		grid-template-columns: auto auto 1fr;
		align-items: flex-end;

		column-gap: 1.5rem;
		row-gap: 1rem;

		padding: 1.25rem 0;
		z-index: 3;
	}

	h1 {
		margin: 0;
		font-size: 1.2rem;
		font-weight: 600;
		line-height: 1;
		white-space: nowrap;
	}

	.logo-group a {
		text-decoration: none;
		color: inherit;
		display: inline-flex;
		align-items: center;
	}

	.role {
		font-size: 0.9rem;
		font-weight: 400;
		opacity: 0.45;
		line-height: 1;
		white-space: nowrap;
		padding-bottom: 0.15rem;
	}

	ul {
		grid-column: 3;
		justify-self: end;

		display: flex;
		align-items: center;
		gap: 2rem;

		margin: 0;
		padding: 0;

		list-style: none;

		font-size: 0.95rem;
		font-weight: 600;
	}

	ul a {
		position: relative;
		text-decoration: none;
		color: inherit;
		padding-bottom: 0.45rem;
		transition: color .2s ease;
	}

	/* 目前頁面 */
	ul a.current::after {
		content: "";
		position: absolute;
		left: 0;
		right: 0;
		bottom: -2px;
		height: 4px;
		background: #000;
	}

	ul a.current {
		pointer-events: none;
	}

	@media (max-width: 768px) {
		header {
			grid-template-columns: auto 1fr;
			column-gap: 0.75rem;
			row-gap: 1rem;
			padding: 1rem 0;
		}

		h1 {
			font-size: 1rem;
		}

		.role {
			font-size: 0.82rem;
			padding-bottom: 0;
		}

		ul {
			grid-column: 1 / -1;
			justify-self: start;
			gap: 1.5rem;
			font-size: 0.95rem;
		}
	}
</style>

<Separator />
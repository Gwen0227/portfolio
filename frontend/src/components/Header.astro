---
import { getCollection } from "astro:content";
import Separator from "../components/Separator.astro";
import TextSlider from "../components/TextSlider.astro";

type Props = {
	activeCategory?: string;
};

const { activeCategory } = Astro.props;

const currentPath = Astro.url.pathname;

// 🎯 1. 統一將當前路徑結尾的斜線去掉，避免路由判定錯誤
const normalizedPath = currentPath.replace(/\/$/, "") || "/";

// 🎯 2. 判斷邏輯：非 /about 與 /contact 的路徑（包含首頁 / 與作品內頁）皆歸為 Projects
let currentTab = "Projects";
if (normalizedPath === "/about") {
	currentTab = "About";
} else if (normalizedPath === "/contact") {
	currentTab = "Contact";
}

// 🎯 3. 自動抓取 Content Collections 中的所有專案分類與總數量
const allProjects = await getCollection("projects");
const rawCategories = Array.from(new Set(allProjects.map((p) => p.data.category).filter(Boolean)));
const categories = ["All", ...rawCategories];

// 預設高亮分類
const currentCategory = activeCategory || "All";
---

<header>
	<div class="header-main">
		<h1 class="logo-group">
			<a href="/">
				<TextSlider content="Chen-Pei Jyuan" />
			</a>
		</h1>

		<span class="role">
			<TextSlider content="Brand & Visual Designer" />
		</span>

		<ul>
			<li>
				<a
					href="/"
					class={currentTab === "Projects" ? "current" : ""}
					data-astro-prefetch
				>
					<TextSlider content="Projects" />
				</a>
			</li>

			<li>
				<a
					href="/about"
					class={currentTab === "About" ? "current" : ""}
					data-astro-prefetch
				>
					<TextSlider content="About" />
				</a>
			</li>

			<li>
				<a
					href="/contact"
					class={currentTab === "Contact" ? "current" : ""}
					data-astro-prefetch
				>
					<TextSlider content="Contact" />
				</a>
			</li>
		</ul>
	</div>

	{currentTab === "Projects" && (
		<div class="category-bar">
			<div class="category-list">
				{categories.map((cat) => {
					const isActive = cat.toLowerCase() === currentCategory.toLowerCase();
					return (
						<a 
							href={cat === "All" ? "/#projects" : `/#projects?category=${cat}`}
							class={`category-item ${isActive ? "is-active" : ""}`}
						>
							{cat}
						</a>
					);
				})}
			</div>
			<div class="category-count">
				{allProjects.length} Projects
			</div>
		</div>
	)}
</header>

<style>
	header {
		position: relative;
		width: 100%;
		z-index: 3;
	}

	.header-main {
		display: grid;
		grid-template-columns: auto auto 1fr;
		align-items: flex-end;
		column-gap: 1.5rem;
		row-gap: 1rem;
		padding: 1.25rem 0;
	}

	h1 {
		margin: 0;
		font-size: 1.2rem;
		font-weight: 600;
		line-height: 1;
		white-space: nowrap;
	}

	.logo-group a {
		text-decoration: none;
		color: #000000;
		position: relative;
		padding-bottom: 0.5rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		pointer-events: auto !important;
	}

	.logo-group a::after {
		display: none !important;
	}

	.role {
		font-size: 0.9rem;
		font-weight: 400;
		opacity: 0.45;
		line-height: 1;
		white-space: nowrap;
		padding-bottom: 0.5rem;
	}

	ul {
		grid-column: 3;
		justify-self: end;
		display: flex;
		align-items: center;
		gap: 2rem;
		margin: 0;
		padding: 0;
		list-style: none;
		font-size: 0.9rem;
		font-weight: 600;
	}

	ul a {
		position: relative;
		text-decoration: none;
		color: #000000;
		padding-bottom: 0.5rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}

	/* 4px 黑色厚底線 */
	ul a.current::after {
		content: "";
		position: absolute;
		left: 0;
		bottom: -2px;
		width: 100%;
		height: 4px
---
import Separator from "../components/Separator.astro";
import TextSlider from "../components/TextSlider.astro";

const currentPath = Astro.url.pathname;

const routes = {
	"/": "Projects",
	"/about/": "About",
	"/contact/": "Contact",
};

const activeRoute = routes[currentPath] || null;
---

<header>
	<h1 class="logo-group">
		<a href="/">
			<TextSlider content="Chen-Pei Jyuan" />
		</a>
	</h1>

	<span class="role">
		<TextSlider content="Brand & Visual Designer" />
	</span>

	<ul>
		<li>
			<a
				href="/"
				class={activeRoute === "Projects" ? "current" : ""}
				data-astro-prefetch
			>
				<TextSlider content="Projects" />
			</a>
		</li>

		<li>
			<a
				href="/about/"
				class={activeRoute === "About" ? "current" : ""}
				data-astro-prefetch
			>
				<TextSlider content="About" />
			</a>
		</li>

		<li>
			<a
				href="/contact/"
				class={activeRoute === "Contact" ? "current" : ""}
				data-astro-prefetch
			>
				<TextSlider content="Contact" />
			</a>
		</li>
	</ul>
</header>

<style>
	header {
		position: relative;
		display: grid;
		grid-template-columns: auto auto 1fr;
		align-items: flex-end;

		column-gap: 1.5rem;
		row-gap: 1rem;

		padding: 1.25rem 0; /* 稍微縮小內距，配合 1rem 的字級 */

		z-index: 3;
	}

	h1 {
		margin: 0;
		font-size: 1rem; /* 🎯 名字同步調回 1rem */
		font-weight: 700;
		line-height: 1;
		white-space: nowrap;
	}

	.logo-group a {
		text-decoration: none;
		color: #000000;
		position: relative;
		padding-bottom: 0.5rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		pointer-events: auto !important;
	}

	.logo-group a::after {
		display: none !important;
	}

	.role {
		font-size: 0.9rem; /* 職稱稍微縮小，維持視覺比例 */
		font-weight: 400;
		opacity: 0.45;
		line-height: 1;
		white-space: nowrap;
		padding-bottom: 0.5rem;
	}

	ul {
		grid-column: 3;
		justify-self: end;

		display: flex;
		align-items: center;
		gap: 2rem;

		margin: 0;
		padding: 0;

		list-style: none;

		font-size: 0.8rem; /* 🎯 主選單（Projects...）成功改回 1rem */
		font-weight: 700;
	}

	ul a {
		position: relative;
		text-decoration: none;
		color: #000000;
		padding-bottom: 0.5rem; /* 微調底線留白距離 */
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}

	/* 🎯 保持好看的 4px 黑色厚底線 */
	ul a.current::after {
		content: "";
		position: absolute;
		left: 0;
		bottom: -2px;
		width: 100%;
		height: 4px;
		background-color: #000000;
	}

	ul a.current {
		pointer-events: none;
	}

	/* 📱 手機版響應式調整 */
	@media (max-width: 768px) {
		header {
			grid-template-columns: auto 1fr;
			column-gap: 0.75rem;
			row-gap: 1.2rem;
			padding: 1rem 0;
		}

		ul {
			grid-column: 1 / -1;
			justify-self: start;
			gap: 1.5rem;
			font-size: 0.95rem;
		}

		h1 {
			font-size: 1rem;
		}

		.role {
			font-size: 0.85rem;
		}
	}
</style>
---
import Separator from "../components/Separator.astro";
import TextSlider from "../components/TextSlider.astro";

const currentPath = Astro.url.pathname;

// 🎯 修正 1：統一將當前路徑結尾的斜線去掉，避免比對出錯
const normalizedPath = currentPath.replace(/\/$/, "") || "/";

const routes = {
	"/": "Projects",
	"/about": "About",    // 🎯 修正 2：去掉尾端斜線
	"/contact": "Contact",// 🎯 修正 2：去掉尾端斜線
};

const activeRoute = routes[normalizedPath] || null;
---

<header>
	<h1 class="logo-group">
		<a href="/">
			<TextSlider content="Chen-Pei Jyuan" />
		</a>
	</h1>

	<span class="role">
		<TextSlider content="Brand & Visual Designer" />
	</span>

	<ul>
		<li>
			<a
				href="/"
				class={normalizedPath === "/" ? "current" : ""}
				data-astro-prefetch
			>
				<TextSlider content="Projects" />
			</a>
		</li>

		<li>
			<!-- 🎯 修正 3：href 改成 /about (不帶斜線) -->
			<a
				href="/about"
				class={activeRoute === "About" ? "current" : ""}
				data-astro-prefetch
			>
				<TextSlider content="About" />
			</a>
		</li>

		<li>
			<!-- 🎯 修正 3：href 改成 /contact (不帶斜線) -->
			<a
				href="/contact"
				class={activeRoute === "Contact" ? "current" : ""}
				data-astro-prefetch
			>
				<TextSlider content="Contact" />
			</a>
		</li>
	</ul>
</header>

<style>
	header {
		position: relative;
		display: grid;
		grid-template-columns: auto auto 1fr;
		align-items: flex-end;
		column-gap: 1.5rem;
		row-gap: 1rem;
		padding: 1.25rem 0;
		z-index: 3;
	}

	h1 {
		margin: 0;
		font-size: 1.2rem;
		font-weight: 600;
		line-height: 1;
		white-space: nowrap;
	}

	.logo-group a {
		text-decoration: none;
		color: #000000;
		position: relative;
		padding-bottom: 0.5rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		pointer-events: auto !important;
	}

	.logo-group a::after {
		display: none !important;
	}

	.role {
		font-size: 0.9rem;
		font-weight: 400;
		opacity: 0.45;
		line-height: 1;
		white-space: nowrap;
		padding-bottom: 0.5rem;
	}

	ul {
		grid-column: 3;
		justify-self: end;
		display: flex;
		align-items: center;
		gap: 2rem;
		margin: 0;
		padding: 0;
		list-style: none;
		font-size: 0.9rem;
		font-weight: 600;
	}

	ul a {
		position: relative;
		text-decoration: none;
		color: #000000;
		padding-bottom: 0.5rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}

	/* 4px 黑色厚底線 */
	ul a.current::after {
		content: "";
		position: absolute;
		left: 0;
		bottom: -2px;
		width: 100%;
		height: 4px;
		background-color: #000000;
	}

	ul a.current {
		pointer-events: none;
	}

	/* 📱 手機版響應式調整 */
	@media (max-width: 768px) {
		header {
			grid-template-columns: auto 1fr;
			column-gap: 0.75rem;
			row-gap: 1.2rem;
			padding: 1rem 0;
		}

		ul {
			grid-column: 1 / -1;
			justify-self: start;
			gap: 1.5rem;
			font-size: 0.95rem;
		}

		h1 {
			font-size: 1rem;
		}

		.role {
			font-size: 0.85rem;
		}
	}
</style>
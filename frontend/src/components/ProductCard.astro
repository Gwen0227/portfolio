---
import type { CollectionEntry } from "astro:content";

type Props = {
	product: CollectionEntry<"projects">;
};

const { product } = Astro.props;

const mode = product.data.mode || "page";
const projectLink = `/${product.data.slug || product.id}`;
const year = product.data.year || "2026";
---

{mode === "zoom" ? (
	<div class="product-card is-zoom-mode" data-zoom={product.data.cover}>
		<div class="image-container">
			<img src={product.data.cover} alt={product.data.title} loading="lazy" class="protected-img" />
		</div>
		<div class="project-info">
			<h3>{product.data.title}</h3>
			<div class="project-meta">
				<span class="category-tag">{product.data.category || "Visual"}</span>
				<span class="year-tag">/{year}</span>
			</div>
		</div>
	</div>
) : (
	<a href={projectLink} class="product-card is-page-mode">
		<div class="image-container">
			<img src={product.data.cover} alt={product.data.title} loading="lazy" class="protected-img" />
		</div>
		<div class="project-info">
			<h3>{product.data.title}</h3>
			<div class="project-meta">
				<span class="category-tag">{product.data.category || "Visual"}</span>
				<span class="year-tag">/{year}</span>
			</div>
		</div>
	</a>
)}

<!-- 🎯 燈箱 Modal 結構 -->
<div id="lightbox-modal" class="lightbox-modal" aria-hidden="true">
	<span class="lightbox-close">&times;</span>
	<img class="lightbox-content" id="lightbox-img" alt="Zoomed view" />
</div>

<script>
	function setupLightbox() {
		const modal = document.getElementById('lightbox-modal');
		const modalImg = document.getElementById('lightbox-img') as HTMLImageElement;
		const closeBtn = document.querySelector('.lightbox-close');

		if (!modal || !modalImg) return;

		document.querySelectorAll('.is-zoom-mode').forEach((card) => {
			card.addEventListener('click', () => {
				const zoomSrc = card.getAttribute('data-zoom');
				if (zoomSrc) {
					modalImg.src = zoomSrc;
					modal.classList.add('is-active');
				}
			});
		});

		const closeModal = () => {
			modal.classList.remove('is-active');
		};

		if (closeBtn) {
			closeBtn.addEventListener('click', closeModal);
		}

		modal.addEventListener('click', (e) => {
			if (e.target === modal || e.target === modalImg) {
				closeModal();
			}
		});

		window.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && modal.classList.contains('is-active')) {
				closeModal();
			}
		});
	}

	setupLightbox();
	document.addEventListener('astro:page-load', setupLightbox);
</script>

<style>
	.product-card,
	.product-card *,
	.product-card:hover,
	.product-card:hover * {
		background-color: transparent !important;
		box-shadow: none !important;
		outline: none !important;
		border: none !important;
	}

	.product-card {
		display: flex !important;
		flex-direction: column !important;
		width: 100% !important;
		text-decoration: none !important;
		color: #000000 !important;
		opacity: 1 !important;
		filter: none !important;
	}

	.is-zoom-mode { cursor: zoom-in; }
	.is-page-mode { cursor: pointer; }

	.image-container {
		width: 100% !important;
		aspect-ratio: 1 / 1 !important;
		height: auto !important;
		overflow: hidden !important;
		position: relative !important;
		background: #ffffff !important;
		opacity: 1 !important;
		filter: none !important;
	}

	.image-container::after {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-color: rgba(0, 0, 0, 0.25);
		opacity: 1;
		transition: opacity 0.3s ease;
		z-index: 1;
		pointer-events: none; /* 防止遮罩干擾滑鼠事件 */
	}

	.protected-img {
		width: 100% !important;
		height: 100% !important;
		object-fit: cover !important;
		display: block !important;
		opacity: 1 !important;
		filter: blur(0.6px) brightness(1) contrast(1) !important;
		transition: filter 0.3s ease;
		user-select: none;
		-webkit-user-drag: none;
		z-index: 0;
	}

	.product-card:hover .image-container::after {
		opacity: 0;
	}

	.product-card:hover .protected-img {
		filter: blur(0) brightness(1) contrast(1) !important;
		opacity: 1 !important;
	}

	.project-info {
		padding: 0.5rem 0 0 0 !important;
		width: 100% !important;
	}

	.project-info h3 {
		margin: 0 !important;
		font-size: 0.95rem !important;
		font-weight: 700 !important;
		line-height: 1.2 !important;
		color: #000000 !important;
	}

	.project-meta {
		display: flex !important;
		flex-direction: row !important;
		justify-content: space-between !important;
		align-items: baseline !important;
		margin-top: 0.2rem !important;
		width: 100% !important;
	}

	.category-tag {
		font-size: 0.8rem !important;
		font-weight: 400 !important;
		color: #888888 !important;
		line-height: 1 !important;
	}

	.year-tag {
		font-size: 0.72rem !important;
		font-weight: 400 !important;
		color: #aaaaaa !important;
	}

	@media (max-width: 768px) {
		.project-info h3 { font-size: 0.9rem !important; }
		.category-tag { font-size: 0.75rem !important; }
		.year-tag { font-size: 0.68rem !important; }
	}
</style>

<!-- 🎯 燈箱預設設為 pointer-events: none，隱藏時絕對不吃掉滑鼠滾輪事件 -->
<style is:global>
	.lightbox-modal {
		display: none;
		position: fixed !important;
		inset: 0 !important;
		z-index: 999999 !important;
		background-color: rgba(0, 0, 0, 0.63) !important;
		align-items: center;
		justify-content: center;
		backdrop-filter: blur(5px);
		cursor: zoom-out;
		pointer-events: none;
	}

	.lightbox-modal.is-active {
		display: flex !important;
		pointer-events: auto !important;
	}

	.lightbox-content {
		max-width: 90vw !important;
		max-height: 90vh !important;
		object-fit: contain !important;
		border-radius: 4px;
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.41);
		user-select: none;
		-webkit-user-drag: none;
	}

	.lightbox-close {
		position: absolute !important;
		top: 20px !important;
		right: 35px !important;
		color: #ffffff !important;
		font-size: 40px !important;
		font-weight: 300 !important;
		cursor: pointer;
		line-height: 1 !important;
		transition: opacity 0.2s ease;
	}

	.lightbox-close:hover {
		opacity: 0.7;
	}
</style>
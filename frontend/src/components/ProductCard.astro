---
import type { CollectionEntry } from "astro:content";

type Props = {
	product: CollectionEntry<"projects">;
};

const { product } = Astro.props;

// 🎯 設定路徑與導向
const mode = product.data.mode || "page";
const projectLink = `/${product.data.slug || product.id}`;

// 🎯 取得年份，若未設定則預設為 2026
const year = product.data.year || "2026";
---

{mode === "zoom" ? (
	<div class="product-card is-zoom-mode">
		<div class="image-container">
			<img src={product.data.cover} alt={product.data.title} loading="lazy" class="protected-img" />
		</div>
		<div class="project-info">
			<h3>{product.data.title}</h3>
			<div class="project-meta">
				<span class="category-tag">{product.data.category || "Visual"}</span>
				<span class="year-tag">/{year}</span>
			</div>
		</div>
	</div>
) : (
	<a href={projectLink} class="product-card is-page-mode">
		<div class="image-container">
			<img src={product.data.cover} alt={product.data.title} loading="lazy" class="protected-img" />
		</div>
		<div class="project-info">
			<h3>{product.data.title}</h3>
			<div class="project-meta">
				<span class="category-tag">{product.data.category || "Visual"}</span>
				<span class="year-tag">/{year}</span>
			</div>
		</div>
	</a>
)}

<style>
	.product-card {
		display: flex;
		flex-direction: column;
		width: 100%;
		text-decoration: none;
		color: #000000;
		background: transparent;
	}

	.is-zoom-mode { cursor: zoom-in; }
	.is-page-mode { cursor: pointer; }

	.image-container {
		width: 100%;
		aspect-ratio: 1 / 1;
		overflow: hidden;
		background: #f5f5f5;
	}

	/* 防盜模糊 */
	.protected-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		display: block;
		filter: blur(0.6px);
		transition: filter 0.3s ease;
		user-select: none;
		-webkit-user-drag: none;
	}

	.product-card:hover .protected-img {
		filter: blur(0);
	}

	.project-info {
		padding: 0.5rem 0 0 0;
	}

	.project-info h3 {
		margin: 0;
		font-size: 0.95rem;
		font-weight: 700;
		line-height: 1.2;
		color: #000000;
	}

	/* 🎯 分類與年份橫向排列 */
	.project-meta {
		display: flex !important;
		flex-direction: row !important;
		justify-content: space-between !important;
		align-items: baseline !important;
		margin-top: 0.2rem;
		width: 100%;
	}

	.category-tag {
		font-size: 0.8rem !important;
		font-weight: 400 !important;
		color: #888888 !important;
		line-height: 1 !important;
	}

	/* 🎯 年份再調小、微調透明度 */
	.year-tag {
		font-size: 0.72rem !important; /* 再調小 */
		font-weight: 400 !important;
		color: #aaaaaa !important; /* 顏色稍微淡一點更細緻 */
		line-height: 1 !important;
	}

	@media (max-width: 768px) {
		.project-info h3 { font-size: 0.9rem; }
		.category-tag { font-size: 0.75rem !important; }
		.year-tag { font-size: 0.68rem !important; }
	}
</style>

<style is:global>
	/* 針對所有可能產生 Hover 黑底懸浮區塊的 Class 做強制屏蔽 */
	[class*="hover-reveal"],
	[class*="cursor-"],
	.hover-reveal,
	.hover-reveal__inner,
	.hover-reveal__img,
	#cursor,
	.cursor {
		display: none !important;
		opacity: 0 !important;
		visibility: hidden !important;
		pointer-events: none !important;
		width: 0 !important;
		height: 0 !important;
	}
</style>
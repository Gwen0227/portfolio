---
import { Image } from 'astro:assets';
import type { CollectionEntry } from "astro:content";

type Props = {
	product: CollectionEntry<"projects">;
};

const { product } = Astro.props;

// 🎯 設定路徑邏輯
const mode = product.data.mode || "page";
const projectLink = `/${product.data.slug || product.id}`;

// 取得所有在 assets 的圖片資源
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/*.{jpeg,jpg,png,webp}');
const imagePath = `/src/assets${product.data.cover}`;
const coverImage = images[imagePath] ? await images[imagePath]() : null;
---

{mode === "zoom" ? (
	<div
		class="product-card is-zoom-mode"
		data-product-title={product.data.title}
		data-zoom={product.data.cover}
	>
		<div class="image-container">
            {coverImage ? (
                <Image src={coverImage} alt={product.data.title} width={600} height={600} format="webp" quality={60} loading="lazy" />
            ) : (
                <img src={product.data.cover} alt={product.data.title} loading="lazy" />
            )}
		</div>
		<div class="project-info">
			<h3>{product.data.title}</h3>
			{product.data.category && <span class="category-tag">{product.data.category}</span>}
		</div>
	</div>
) : (
	<a href={projectLink} class="product-card is-page-mode" data-product-title={product.data.title}>
		<div class="image-container">
            {coverImage ? (
                <Image src={coverImage} alt={product.data.title} width={600} height={600} format="webp" quality={60} loading="lazy" />
            ) : (
                <img src={product.data.cover} alt={product.data.title} loading="lazy" />
            )}
		</div>
		<div class="project-info">
			<h3>{product.data.title}</h3>
			{product.data.category && <span class="category-tag">{product.data.category}</span>}
		</div>
	</a>
)}

<style>
	.product-card {
		display: flex;
		flex-direction: column;
		width: 100%;
		text-decoration: none;
		color: #000000;
		background: #ffffff;
		transition: transform 0.2s ease;
	}

	.product-card:hover {
		transform: translateY(-2px);
	}
	
	.is-zoom-mode { cursor: zoom-in; }
	.is-page-mode { cursor: pointer; }

	.image-container {
		width: 100%;
		aspect-ratio: 1 / 1;
		overflow: hidden;
		background: #f5f5f5;
	}

	/* 讓圖片強制填滿容器 */
	.image-container img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		display: block;
	}

	.project-info {
		padding: 0.75rem 0.25rem;
	}

	.project-info h3 {
		margin: 0;
		font-size: 0.95rem;
		font-weight: 600;
		line-height: 1.2;
	}

	.category-tag {
		font-size: 0.8rem;
		color: #666666;
		margin-top: 0.2rem;
		display: block;
	}

	@media (max-width: 768px) {
		.project-info h3 { font-size: 0.9rem; }
	}
</style>
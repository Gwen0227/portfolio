---
import type { CollectionEntry } from "astro:content";

type Props = {
	product: CollectionEntry<"projects">;
};

const { product } = Astro.props;

// 🎯 讀取個別作品的設定，沒寫的話預設是 "page" (進入說明頁)
const mode = product.data.mode || "page";
const projectLink = `/projects/${product.data.slug || product.id}`;
---

{mode === "zoom" ? (
	<div
		class="product-card is-zoom-mode"
		data-product-title={product.data.title}
		data-zoom={product.data.cover}
	>
		<article>
			<div class="img-container">
				<img
					src={product.data.cover}
					alt={product.data.title}
					loading="lazy"
				/>
			</div>

			<div class="product-meta">
				<h3>{product.data.title}</h3>
				<p>{product.data.year}</p>
			</div>
		</article>
	</div>
) : (
	<a
		class="product-card is-page-mode"
		data-product-title={product.data.title}
		data-astro-prefetch
		href={projectLink}
	>
		<article>
			<div class="img-container">
				<img
					src={product.data.cover}
					alt={product.data.title}
					loading="lazy"
				/>
			</div>

			<div class="product-meta">
				<h3>{product.data.title}</h3>
				<p>{product.data.year}</p>
			</div>
		</article>
	</a>
)}

<style>
	.product-card {
		display: block;
		width: 100%;
		text-decoration: none;
		color: inherit;
	}

	/* 🎯 依據模式切換滑鼠游標 */
	.is-zoom-mode {
		cursor: zoom-in;
	}

	.is-page-mode {
		cursor: pointer;
	}

	article {
		width: 100%;
	}

	/* 🚀 新增外層容器：強迫鎖死 1:1 正方形基地 */
	.img-container {
		width: 100%;
		aspect-ratio: 1 / 1;
		overflow: hidden;
		display: block;
	}

	/* 🎯 圖片完美填滿 1:1，等比例裁切、絕對不拉伸變形 */
	img {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
		object-position: center;
	}

	.product-meta {
		display: flex;
		align-items: baseline;
		gap: 0.4rem;

		margin-top: 0.35rem;
	}

	h3 {
		margin: 0;

		font-size: 0.95rem;
		font-weight: 700;
		line-height: 1.1;
	}

	p {
		margin: 0;

		font-size: 0.95rem;
		font-weight: 400;

		opacity: 0.45;

		line-height: 1.1;
	}

	@media (max-width: 768px) {
		h3,
		p {
			font-size: 0.9rem;
		}
	}
</style>
---
import type { CollectionEntry } from "astro:content";

type Props = {
	product: CollectionEntry<"projects">;
};

const { product } = Astro.props;
---

<a
	class="product-card"
	data-product-title={product.data.title}
	data-astro-prefetch
	href="#"
>
	<article>
		<img
			src={product.data.cover}
			alt={product.data.title}
			loading="lazy"
		/>

		<div class="product-meta">
			<h3>{product.data.title}</h3>
			<p>{product.data.year}</p>
		</div>
	</article>
</a>

<style>
	.product-card {
		display: block;
		width: 100%;
	}

	article {
		width: 100%;
	}

	img {
		width: 100%;
		display: block;

		aspect-ratio: 1 / 1;
		object-fit: cover;
	}

	.product-meta {
		display: flex;
		align-items: baseline;
		gap: 0.4rem;

		margin-top: 0.35rem;
	}

	h3 {
		margin: 0;

		font-size: 0.95rem;
		font-weight: 700;
		line-height: 1.1;
	}

	p {
		margin: 0;

		font-size: 0.95rem;
		font-weight: 400;

		opacity: 0.45;

		line-height: 1.1;
	}

	@media (max-width: 768px) {
		h3,
		p {
			font-size: 0.9rem;
		}
	}
</style>
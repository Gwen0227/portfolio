---
import type { CollectionEntry } from "astro:content";

type Props = {
	product: CollectionEntry<"projects">;
};

const { product } = Astro.props;

// 🎯 設定路徑與導向
const mode = product.data.mode || "page";
const projectLink = `/${product.data.slug || product.id}`;
---

{mode === "zoom" ? (
	<div
		class="product-card is-zoom-mode"
		data-product-title={product.data.title}
		data-zoom={product.data.cover}
	>
		<div class="image-container">
			<img src={product.data.cover} alt={product.data.title} loading="lazy" class="protected-img" />
		</div>
		<div class="project-info">
			<h3>{product.data.title}</h3>
			{product.data.category && <span class="category-tag">{product.data.category}</span>}
		</div>
	</div>
) : (
	<a href={projectLink} class="product-card is-page-mode" data-product-title={product.data.title}>
		<div class="image-container">
			<img src={product.data.cover} alt={product.data.title} loading="lazy" class="protected-img" />
		</div>
		<div class="project-info">
			<h3>{product.data.title}</h3>
			{product.data.category && <span class="category-tag">{product.data.category}</span>}
		</div>
	</a>
)}

<style>
	.product-card {
		display: flex;
		flex-direction: column;
		width: 100%;
		text-decoration: none;
		color: #000000;
		background: #ffffff;
		transition: transform 0.2s ease;
	}

	.product-card:hover {
		transform: translateY(-2px);
	}
	
	.is-zoom-mode { cursor: zoom-in; }
	.is-page-mode { cursor: pointer; }

	.image-container {
		width: 100%;
		aspect-ratio: 1 / 1;
		overflow: hidden;
		background: #f5f5f5;
	}

	/* 🚀 核心防護：AI 防護與防盜設計 */
	.protected-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		display: block;
		
		/* 透過模糊濾鏡擾亂 AI 採樣，對人類視覺影響微小 */
		filter: blur(0.6px);
		transition: filter 0.3s ease;
		
		/* 禁止使用者拖曳圖片 */
		user-select: none;
		-webkit-user-drag: none;
	}

	/* 滑鼠移入時清晰，保障良好觀看體驗 */
	.product-card:hover .protected-img {
		filter: blur(0);
	}

	.project-info {
		padding: 0.75rem 0.25rem;
	}

	.project-info h3 {
		margin: 0;
		font-size: 0.95rem;
		font-weight: 600;
		line-height: 1.2;
	}

	.category-tag {
		font-size: 0.8rem;
		color: #666666;
		margin-top: 0.2rem;
		display: block;
	}

	@media (max-width: 768px) {
		.project-info h3 { font-size: 0.9rem; }
	}
</style>
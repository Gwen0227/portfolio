---
import type { CollectionEntry } from "astro:content";
import ProductCard from "./ProductCard.astro";

type Props = {
	projects: CollectionEntry<"projects">[];
};

const { projects } = Astro.props;
const grid = "projects";
---

<section class="product-grid" id="grid" data-grid={grid}>
	{projects.map((project) => {
		const currentCategory = project.data.category || "None";
		return (
			<div data-category={currentCategory} class="grid-item">
				<ProductCard product={project} />
			</div>
		);
	})}
</section>

<div id="lightbox-modal" class="lightbox">
	<span class="close-lightbox">&times;</span>
	<img class="lightbox-content" id="lightbox-img" src="" alt="Enlarged view" />
</div>

<script>
	function initLightbox() {
		const modal = document.getElementById('lightbox-modal');
		const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
		const closeBtn = document.querySelector('.close-lightbox');
		const zoomCards = document.querySelectorAll('[data-zoom]');

		if (!modal || !lightboxImg) return;

		zoomCards.forEach(card => {
			card.addEventListener('click', () => {
				const largeImgUrl = card.getAttribute('data-zoom');
				if (largeImgUrl) {
					lightboxImg.src = largeImgUrl;
					modal.classList.add('active');
					document.body.style.overflow = 'hidden';
				}
			});
		});

		closeBtn?.addEventListener('click', closeModal);
		modal.addEventListener('click', (e) => {
			if (e.target === modal) closeModal();
		});

		function closeModal() {
			modal.classList.remove('active');
			document.body.style.overflow = '';
			setTimeout(() => { lightboxImg.src = ''; }, 300);
		}
	}

	initLightbox();
	document.addEventListener('astro:page-load', initLightbox);
</script>

<style>
	.product-grid {
		position: relative;
		overflow: hidden;
		display: grid;
		width: 100%;
		/* 📱 預設 / 小螢幕（最小狀態）：一排 3 張 */
		grid-template-columns: repeat(3, minmax(0, 1fr));
		/* 完全保留你原本的間距設定 */
		gap: 1rem 0.2rem; 
		margin: 1rem 0 6rem;
		min-height: 400px;
	}
       
	.grid-item {
		display: block;
		width: 100%;
	}

	.lightbox {
		position: fixed;
		z-index: 9999;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-color: rgba(0, 0, 0, 0.95);
		display: flex;
		justify-content: center;
		align-items: center;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.3s ease;
	}

	.lightbox.active {
		opacity: 1;
		pointer-events: auto;
	}

	.lightbox-content {
		max-width: 90%;
		max-height: 85vh;
		object-fit: contain;
		transform: scale(0.97);
		transition: transform 0.3s ease;
	}

	.lightbox.active .lightbox-content {
		transform: scale(1);
	}

	.close-lightbox {
		position: absolute;
		top: 20px;
		right: 30px;
		color: #ffffff;
		font-size: 40px;
		font-weight: 200;
		cursor: pointer;
	}

	/* 💻 中大螢幕（約 > 1024px）：一排 5 張 */
	@media screen and (min-width: 64em) {
		.product-grid { 
			grid-template-columns: repeat(5, minmax(0, 1fr)) !important; 
		}
	}

	/* 🖥️ 大螢幕 / 桌機（約 > 1280px）：一排 6 張 */
	@media screen and (min-width: 80em) {
		.product-grid { 
			grid-template-columns: repeat(6, minmax(0, 1fr)) !important; 
		}
	}
</style>
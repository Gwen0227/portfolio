---
import type { CollectionEntry } from "astro:content";
import ProductCard from "./ProductCard.astro";
import ProductTooltip from "./ProductTooltip.astro";

type Props = {
	projects: CollectionEntry<"projects">[];
};

const { projects } = Astro.props;
const grid = "projects";
---

<section
	class="product-grid"
	id="grid"
	data-grid={grid}
>
	{projects.map((project) => {
		// 🎯 這裡已經改回對齊你的 .md 欄位：category
		const currentCategory = project.data.category || "None";
		
		return (
			<div data-category={currentCategory} class="grid-item">
				<ProductCard product={project} />
			</div>
		);
	})}
</section>

<ProductTooltip grid={grid} />

<style>
	.product-grid {
		position: relative;
		overflow: hidden;
		display: grid;
		width: 100%;
		grid-template-columns: repeat(3, 1fr);
		gap: 0rem;
		margin: 1rem 0 10rem;
		min-height: 400px;
	}

	.grid-item {
		display: block;
		width: 100%;
		height: 100%;
	}

	@media screen and (min-width: 50em) {
		.product-grid {
			grid-template-columns: repeat(4, 1fr);
		}
	}

	@media screen and (min-width: 80em) {
		.product-grid {
			grid-template-columns: repeat(5, 1fr);
		}
	}
</style>
---
import TextSlider from "../components/TextSlider.astro";

type Props = {
	productsTotal?: number;
	activeCategory?: string;
};

const { productsTotal = 3, activeCategory = "all" } = Astro.props;

const categories = [
	{ id: "all", label: "All" },
	{ id: "Brand", label: "Brand" },
	{ id: "Visual", label: "Visual" },
	{ id: "Packaging", label: "Packaging" },
];
---

<div class="category-wrapper">
	<div class="full-width-bg"></div>

	<header class="project-filter">
		<div class="categories">
			{categories.map((cat) => {
				const isActive = cat.id.toLowerCase() === activeCategory.toLowerCase();
				return (
					<button 
						data-filter={cat.id} 
						class={isActive ? "active" : ""}
					>
						<TextSlider content={cat.label} />
					</button>
				);
			})}
		</div>

		<span class="count">
			<TextSlider content={`${productsTotal} Projects`} />
		</span>
	</header>
</div>

<script>
	function initFilter() {
		const buttons = document.querySelectorAll('.categories button');
		const cards = document.querySelectorAll('[data-category]') as NodeListOf<HTMLElement>;

		if (!buttons.length) return;

		// 🎯 核心執行函式：從目前網址列 (window.location.search) 讀取分類並篩選
		function syncCategoryFromUrl() {
			const urlParams = new URLSearchParams(window.location.search);
			const currentCategory = (urlParams.get('category') || 'all').toLowerCase();

			// 1. 高亮正確按鈕
			buttons.forEach(btn => {
				const filterVal = (btn.getAttribute('data-filter') || '').toLowerCase();
				if (filterVal === currentCategory) {
					btn.classList.add('active');
				} else {
					btn.classList.remove('active');
				}
			});

			// 2. 顯示/隱藏對應卡片
			cards.forEach(card => {
				const cardCategory = (card.getAttribute('data-category') || '').toLowerCase();
				if (currentCategory === 'all' || cardCategory === currentCategory) {
					card.style.display = '';
				} else {
					card.style.display = 'none';
				}
			});
		}

		// 首次載入/切換頁面時同步
		syncCategoryFromUrl();

		// 🎯 按鈕點擊事件
		buttons.forEach(button => {
			// 先清除舊事件避免重複綁定
			const newBtn = button.cloneNode(true) as HTMLElement;
			button.parentNode?.replaceChild(newBtn, button);

			newBtn.addEventListener('click', () => {
				const filterValue = (newBtn.getAttribute('data-filter') || 'all').toLowerCase();

				// 若不在首頁，強制跳回首頁並帶分類參數
				if (window.location.pathname !== "/") {
					window.location.href = filterValue === "all" ? "/" : `/?category=${filterValue}`;
					return;
				}

				// 更新網址列但不刷頁
				const newUrl = filterValue === 'all' ? '/' : `/?category=${filterValue}`;
				window.history.pushState({ category: filterValue }, '', newUrl);

				// 手動觸發同步
				syncCategoryFromUrl();
			});
		});

		// 🎯 關鍵：監聽瀏覽器上一頁/下一頁 (popstate) 事件
		window.addEventListener('popstate', syncCategoryFromUrl);
	}

	// 初始化與 Astro 轉場監聽
	initFilter();
	document.addEventListener('astro:page-load', initFilter);
	document.addEventListener('astro:after-swap', initFilter);
	window.addEventListener('pageshow', initFilter); // 應對瀏覽器 bfcache (快取返回)
</script>

<style>
	.category-wrapper {
		position: relative;
		width: 100%;
		margin-top: 0.5rem;
		margin-bottom: 0.5rem;
	}

	.full-width-bg {
		position: absolute;
		top: 0;
		bottom: 0;
		left: 50%;
		width: 100vw;
		transform: translateX(-50%);
		background-color: #f1f1f1;
		z-index: 0;
	}

	.project-filter {
		position: relative;
		z-index: 1;
		width: 100%;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.15rem 0;
		font-size: 0.85rem; 
		box-sizing: border-box;
		white-space: nowrap;
	}

	.categories {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		overflow-x: auto;
		scrollbar-width: none;
	}

	.categories::-webkit-scrollbar {
		display: none;
	}

	.categories button {
		background: transparent;
		border: none;
		padding: 0.2rem 0;
		font-family: inherit;
		font-size: inherit;
		font-weight: normal; 
		cursor: pointer;
		color: #888888;
		transition: color 0.2s ease, font-weight 0.2s ease;
		flex-shrink: 0;
	}

	.categories button.active {
		color: #000000;
		font-weight: 700;
	}

	.categories button:hover {
		color: #000000;
	}

	.count {
		font-weight: normal; 
		color: #888888;
		white-space: nowrap;
		flex-shrink: 0;
		margin-left: 1rem;
	}

	@media (max-width: 768px) {
		.categories {
			gap: 1rem;
		}
	}
</style>
---
import TextSlider from "../components/TextSlider.astro";

type Props = {
	productsTotal?: number;
	activeCategory?: string;
};

const { productsTotal = 3, activeCategory = "all" } = Astro.props;

// 預設分類清單
const categories = [
	{ id: "all", label: "All" },
	{ id: "Brand", label: "Brand" },
	{ id: "Visual", label: "Visual" },
	{ id: "Packaging", label: "Packaging" },
];
---

<div class="category-wrapper">
	<header class="project-filter">
		<div class="categories">
			{categories.map((cat) => {
				const isActive = cat.id.toLowerCase() === activeCategory.toLowerCase();
				return (
					<button 
						data-filter={cat.id} 
						class={isActive ? "active" : ""}
					>
						<TextSlider content={cat.label} />
					</button>
				);
			})}
		</div>

		<span class="count">
			<TextSlider content={`${productsTotal} Projects`} />
		</span>
	</header>
</div>

<script>
	function initFilter() {
		const buttons = document.querySelectorAll('.categories button');
		const cards = document.querySelectorAll('[data-category]') as NodeListOf<HTMLElement>;

		if (!buttons.length) return;

		buttons.forEach(button => {
			button.addEventListener('click', () => {
				const filterValue = button.getAttribute('data-filter');

				buttons.forEach(btn => btn.classList.remove('active'));
				button.classList.add('active');

				// 如果不在首頁，點擊分類按鈕時跳回首頁並帶上參數
				if (window.location.pathname !== "/") {
					window.location.href = filterValue === "all" ? "/" : `/?category=${filterValue}`;
					return;
				}

				cards.forEach(card => {
					const cardCategory = card.getAttribute('data-category');

					if (filterValue === 'all' || cardCategory === filterValue) {
						card.style.display = '';
						card.style.opacity = '1';
					} else {
						card.style.display = 'none';
					}
				});
			});
		});
	}

	initFilter();
	document.addEventListener('astro:page-load', initFilter);
</script>

<style>
	/* 🎯 滿版灰底容器 (壓縮高度) */
	.category-wrapper {
		width: 100vw;
		position: relative;
		left: 50%;
		right: 50%;
		margin-left: -50vw;
		margin-right: -50vw;
		background-color: #e5e5e5; /* 灰色背景 */
		margin-top: 0.5rem;       /* 上方邊距壓低 */
		margin-bottom: 1.5rem;    /* 下方邊距壓低 */
	}

	.project-filter {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.25rem 2rem;    /* 關鍵：上下 padding 從 0.6rem 縮減到 0.25rem */
		font-size: 0.85rem; 
		box-sizing: border-box;
		white-space: nowrap;
	}

	.categories {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		overflow-x: auto;
		scrollbar-width: none;
	}

	.categories::-webkit-scrollbar {
		display: none;
	}

	.categories button {
		background: transparent;
		border: none;
		padding: 0.2rem 0;        /* 關鍵：按鈕上下 padding 壓低 */

		font-family: inherit;
		font-size: inherit;
		font-weight: normal; 
		
		cursor: pointer;
		color: #888888;

		transition: color 0.2s ease, font-weight 0.2s ease;
		flex-shrink: 0;
	}

	.categories button.active {
		color: #000000;
		font-weight: 700;
	}

	.categories button:hover {
		color: #000000;
	}

	.count {
		font-weight: normal; 
		color: #888888;
		white-space: nowrap;
		flex-shrink: 0;
		margin-left: 1rem;
	}

	@media (max-width: 768px) {
		.project-filter {
			padding: 0.25rem 1rem;
		}

		.categories {
			gap: 1rem;
		}
	}
</style>
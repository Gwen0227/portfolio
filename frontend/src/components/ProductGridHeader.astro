---
import Separator from "../components/Separator.astro";
import TextSlider from "../components/TextSlider.astro";

type Props = {
	productsTotal: number;
};

const { productsTotal } = Astro.props;
---

<header class="project-filter">
	<div class="categories">
		<button data-filter="all" class="active">
			<TextSlider content="All" />
		</button>

		<button data-filter="Brand">
			<TextSlider content="Brand" />
		</button>

		<button data-filter="Visual">
			<TextSlider content="Visual" />
		</button>

		<button data-filter="Packaging">
			<TextSlider content="Packaging" />
		</button>
	</div>

	<span class="count">
		<TextSlider content={`${productsTotal} Projects`} />
	</span>
</header>

<Separator />

<script>
	function initFilter() {
		console.log("=== 🔍 篩選系統啟動 ===");
		
		const buttons = document.querySelectorAll('.categories button');
		const cards = document.querySelectorAll('[data-category]') as NodeListOf<HTMLElement>;

		console.log(`找到按鈕數量: ${buttons.length} 個`);
		console.log(`找到蓋有印章的作品卡片數量: ${cards.length} 個`);

		if (!buttons.length) return;

		buttons.forEach(button => {
			button.addEventListener('click', () => {
				const filterValue = button.getAttribute('data-filter');
				console.log(`👉 你點擊了分類: ${filterValue}`);

				buttons.forEach(btn => btn.classList.remove('active'));
				button.classList.add('active');

				cards.forEach(card => {
					const cardCategory = card.getAttribute('data-category');
					console.log(`卡片對應的分類是: [${cardCategory}]`);

					if (filterValue === 'all' || cardCategory === filterValue) {
						card.style.display = '';
						card.style.opacity = '1';
					} else {
						card.style.display = 'none';
					}
				});
			});
		});
	}

	initFilter();
	document.addEventListener('astro:page-load', initFilter);
</script>

<style>
	.project-filter {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.75rem 0;
		font-size: 0.9rem; 
	}

	.categories {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.categories button {
		background: transparent;
		border: none;
		padding: 0.35rem 0;

		font-family: inherit;
		font-size: inherit;
		font-weight: normal; 
		
		cursor: pointer;
		color: #000000;

		transition: opacity 0.2s ease, font-weight 0.2s ease;
		opacity: 0.4; 
	}

	.categories button.active {
		opacity: 1;
		font-weight: 600;
	}

	.categories button:hover {
		opacity: 0.8;
	}

	.count {
		font-weight: normal; 
		color: #000000;
		opacity: 1;
		white-space: nowrap;
	}

	@media (max-width: 768px) {
		.project-filter {
			flex-wrap: nowrap; 
		}

		.categories {
			gap: 0.75rem;
		}

		.categories button {
			padding: 0.3rem 0;
		}
	}
</style>
---
import TextSlider from "../components/TextSlider.astro";

type Props = {
	productsTotal?: number;
	activeCategory?: string;
};

const { productsTotal = 3, activeCategory = "all" } = Astro.props;

const categories = [
	{ id: "all", label: "All" },
	{ id: "Brand", label: "Brand" },
	{ id: "Visual", label: "Visual" },
	{ id: "Packaging", label: "Packaging" },
];
---

<div class="category-wrapper">
	<div class="full-width-bg"></div>

	<header class="project-filter">
		<div class="categories">
			{categories.map((cat) => {
				const isActive = cat.id.toLowerCase() === activeCategory.toLowerCase();
				return (
					<button 
						data-filter={cat.id} 
						class={isActive ? "active" : ""}
					>
						<TextSlider content={cat.label} />
					</button>
				);
			})}
		</div>

		<span class="count">
			<TextSlider content={`${productsTotal} Projects`} />
		</span>
	</header>
</div>

<script>
	function updateCardLinks(category: string) {
		const links = document.querySelectorAll('a[href*="/projects/"]') as NodeListOf<HTMLAnchorElement>;
		links.forEach(link => {
			const cleanUrl = link.href.split('?')[0];
			link.href = `${cleanUrl}?ref=${category.toLowerCase()}`;
		});
	}

	function initFilter() {
		const buttons = document.querySelectorAll('.categories button');
		const cards = document.querySelectorAll('[data-category]') as NodeListOf<HTMLElement>;

		if (!buttons.length) return;

		// 🎯 1. 初始化讀取 URL
		const urlParams = new URLSearchParams(window.location.search);
		const currentCategory = urlParams.get('category') || 'all';

		buttons.forEach(btn => {
			const filterVal = btn.getAttribute('data-filter') || '';
			if (filterVal.toLowerCase() === currentCategory.toLowerCase()) {
				btn.classList.add('active');
			} else {
				btn.classList.remove('active');
			}
		});

		// 隱藏卡片並更新卡片連結的 ?ref= 參數
		cards.forEach(card => {
			const cardCategory = card.getAttribute('data-category');
			if (!currentCategory || currentCategory.toLowerCase() === 'all' || (cardCategory && cardCategory.toLowerCase() === currentCategory.toLowerCase())) {
				card.style.display = '';
			} else {
				card.style.display = 'none';
			}
		});

		updateCardLinks(currentCategory);

		// 🎯 2. 按鈕點擊切換
		buttons.forEach(button => {
			button.addEventListener('click', () => {
				const filterValue = (button.getAttribute('data-filter') || 'all').toLowerCase();

				buttons.forEach(btn => btn.classList.remove('active'));
				button.classList.add('active');

				if (window.location.pathname !== "/") {
					window.location.href = filterValue === "all" ? "/" : `/?category=${filterValue}`;
					return;
				}

				const newUrl = filterValue === 'all' ? '/' : `/?category=${filterValue}`;
				window.history.replaceState({}, '', newUrl);

				cards.forEach(card => {
					const cardCategory = card.getAttribute('data-category');
					if (filterValue === 'all' || (cardCategory && cardCategory.toLowerCase() === filterValue)) {
						card.style.display = '';
					} else {
						card.style.display = 'none';
					}
				});

				updateCardLinks(filterValue);
			});
		});
	}

	initFilter();
	document.addEventListener('astro:page-load', initFilter);
</script>

<style>
	.category-wrapper {
		position: relative;
		width: 100%;
		margin-top: 0.5rem;
		margin-bottom: 0.5rem;
	}

	.full-width-bg {
		position: absolute;
		top: 0;
		bottom: 0;
		left: 50%;
		width: 100vw;
		transform: translateX(-50%);
		background-color: #f1f1f1;
		z-index: 0;
	}

	.project-filter {
		position: relative;
		z-index: 1;
		width: 100%;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.15rem 0;
		font-size: 0.85rem; 
		box-sizing: border-box;
		white-space: nowrap;
	}

	.categories {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		overflow-x: auto;
		scrollbar-width: none;
	}

	.categories::-webkit-scrollbar {
		display: none;
	}

	.categories button {
		background: transparent;
		border: none;
		padding: 0.2rem 0;
		font-family: inherit;
		font-size: inherit;
		font-weight: normal; 
		cursor: pointer;
		color: #888888;
		transition: color 0.2s ease, font-weight 0.2s ease;
		flex-shrink: 0;
	}

	.categories button.active {
		color: #000000;
		font-weight: 700;
	}

	.categories button:hover {
		color: #000000;
	}

	.count {
		font-weight: normal; 
		color: #888888;
		white-space: nowrap;
		flex-shrink: 0;
		margin-left: 1rem;
	}

	@media (max-width: 768px) {
		.categories {
			gap: 1rem;
		}
	}
</style>
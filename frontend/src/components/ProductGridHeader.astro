---
import Separator from "../components/Separator.astro";
import TextSlider from "../components/TextSlider.astro";

type Props = {
	productsTotal: number;
};

const { productsTotal } = Astro.props;
---

<header class="project-filter">
	<div class="categories">
		<button>
			<TextSlider content="品牌設計" />
		</button>

		<button>
			<TextSlider content="視覺設計" />
		</button>

		<button>
			<TextSlider content="包裝設計" />
		</button>
	</div>

	<span class="count">
		<TextSlider content={`${productsTotal} Projects`} />
	</span>
</header>

<Separator />

<style>
	.project-filter {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.75rem 0;
		/* 確保整列的字體比主選單小，這裡設定 0.9rem（可依設計稿微調） */
		font-size: 0.9rem; 
	}

	.categories {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.categories button {
		background: transparent;
		border: none;
		padding: 0.35rem 0;

		/* 強制使用一般字重，不繼承可能從上層帶來的粗體 */
		font-family: inherit;
		font-size: inherit;
		font-weight: normal; 
		
		cursor: pointer;
		color: #000000;

		transition: opacity 0.2s ease;
		opacity: 1;
	}

	.categories button:hover {
		opacity: 0.7;
	}

	.count {
		/* 改回一般字重（normal），並維持全黑不透明 */
		font-weight: normal; 
		color: #000000;
		opacity: 1;
		white-space: nowrap;
	}

	@media (max-width: 768px) {
		.project-filter {
			flex-wrap: nowrap; 
		}

		.categories {
			gap: 0.75rem;
		}

		.categories button {
			padding: 0.3rem 0;
		}
	}
</style>
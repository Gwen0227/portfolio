---
import TextSlider from "../components/TextSlider.astro";

type Props = {
	productsTotal?: number;
	activeCategory?: string;
};

const { productsTotal = 0, activeCategory = "all" } = Astro.props;

const categories = [
	{ id: "all", label: "All" },
	{ id: "Brand", label: "Brand" },
	{ id: "Visual", label: "Visual" },
	{ id: "Packaging", label: "Packaging" },
];
---

<div class="category-wrapper">
	<div class="full-width-bg"></div>

	<header class="project-filter">
		<div class="categories">
			{categories.map((cat) => {
				const isActive = cat.id.toLowerCase() === activeCategory.toLowerCase();
				const href = cat.id.toLowerCase() === "all" ? "/" : `/?category=${cat.id.toLowerCase()}`;
				
				return (
					<a 
						href={href} 
						class={`category-btn ${isActive ? "active" : ""}`}
					>
						<TextSlider content={cat.label} />
					</a>
				);
			})}
		</div>

		<span class="count">
			<TextSlider content={`${productsTotal} Projects`} />
		</span>
	</header>
</div>

<style>
	.category-wrapper {
		position: relative;
		width: 100%;
		margin-top: 0.5rem;
		margin-bottom: 0.5rem;
	}

	.full-width-bg {
		position: absolute;
		top: 0;
		bottom: 0;
		left: 50%;
		width: 100vw;
		transform: translateX(-50%);
		background-color: #f1f1f1;
		z-index: 0;
	}

	.project-filter {
		position: relative;
		z-index: 1;
		width: 100%;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.15rem 0;
		font-size: 0.85rem; 
		box-sizing: border-box;
		white-space: nowrap;
	}

	.categories {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		overflow-x: auto;
		scrollbar-width: none;
	}

	.categories::-webkit-scrollbar {
		display: none;
	}

	.category-btn {
		background: transparent;
		border: none;
		padding: 0.2rem 0;
		font-family: inherit;
		font-size: inherit;
		font-weight: normal; 
		cursor: pointer;
		color: #888888;
		text-decoration: none;
		transition: color 0.2s ease, font-weight 0.2s ease;
		flex-shrink: 0;
		display: inline-block;
	}

	.category-btn.active {
		color: #000000;
		font-weight: 700;
	}

	.category-btn:hover {
		color: #000000;
	}

	.count {
		font-weight: normal; 
		color: #888888;
		white-space: nowrap;
		flex-shrink: 0;
		margin-left: 1rem;
	}

	@media (max-width: 768px) {
		.categories {
			gap: 1rem;
		}
	}
</style>
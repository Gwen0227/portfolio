---
import Separator from "../components/Separator.astro";

const currentYear = new Date().getFullYear();
---

<Separator />

<footer>
  <p>© {currentYear} Chen-Pei Jyuan. All rights reserved.</p>
</footer>

<style>
  footer {
    padding: 2rem 0;
  }
  p {
    margin: 0;
    font-weight: bold;
    line-height: 1.4;
    text-align: center;
    color: var(--color-text-alt);
  }
</style>
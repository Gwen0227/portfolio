---
import Separator from "../components/Separator.astro";

const currentYear = new Date().getFullYear();
---

<Separator />

<footer>
  <p>© {currentYear} Chen-Pei Jyuan. All rights reserved.</p>
  <p>dashra87549@gmail.com</p>
</footer>

<style>
  footer {
    padding: 1.5rem 0;
  }
  p {
    margin: 0;
    font-size: 0.7rem;        /* 🎯 調小字體 (原本約 1rem) */
    font-weight: 400;          /* 🎯 改為正常/偏細粗細 (原本為 bold/700) */
    opacity: 0.5;              /* 🎯 降低透明度，視覺上更輕盈 */
    line-height: 1.2;
    text-align: center;
    color: var(--color-text-alt);
  }
</style>
---
import { ClientRouter } from "astro:transitions";

import "../styles/global.css";

import { SEO } from "astro-seo";

import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import SmoothScroll from "../components/SmoothScroll.astro";

import "@fontsource-variable/instrument-sans";
import instrumentSansWoff2 from "@fontsource-variable/instrument-sans/files/instrument-sans-latin-wght-normal.woff2";

type Props = {
	title: string;
	description?: string;
};

const { title, description = "陳沛涓的個人作品集" } = Astro.props;

const currentPage =
	Astro.url.pathname.replace(/\/$/, "").split("/").pop() || "home";
---

<!doctype html>
<html lang="en" data-page={currentPage}>
  <head>
    <SEO
      title={title}
      description={description}
      charset="UTF-8"
      openGraph={{
        basic: {
          title: title,
          type: "image/jpeg",
          image: "/playersclub-og.jpg",
        },
      }}
      extend={{
        link: [
          {
            rel: "icon",
            type: "image/png",
            sizes: "16x16",
            href: "/favicon/favicon-16x16.png",
          },
          {
            rel: "icon",
            type: "image/png",
            sizes: "32x32",
            href: "/favicon/favicon-32x32.png",
          },
          {
            rel: "apple-touch-icon",
            sizes: "180x180",
            href: "/favicon/apple-touch-icon.png",
          },
          { rel: "manifest", href: "/favicon/site.webmanifest" },
          { rel: "sitemap", href: "/sitemap-index.xml" },
          {
            rel: "preload",
            href: instrumentSansWoff2,
            as: "font",
            type: "font/woff2",
            crossorigin: "anonymous",
          },
        ],
        meta: [
          { name: "viewport", content: "width=device-width" },
          { name: "msapplication-TileColor", content: "#000000" },
          { name: "theme-color", content: "#ffffff" },
          { name: "generator", content: Astro.generator },
        ],
      }}
    />
    <ClientRouter />

    <style is:global>
      *, *::before, *::after {
        box-sizing: border-box !important;
      }

      html, body {
        height: 100%;
        margin: 0;
        padding: 0;
        overflow-x: hidden; /* 防止任何元素超出導致左右留白消失 */
      }

      .hover-reveal,
      [class*="hover-reveal"],
      [class*="cursor"],
      #cursor,
      canvas.hover-canvas {
        display: none !important;
        opacity: 0 !important;
        visibility: hidden !important;
        pointer-events: none !important;
      }

      /* 🎯 全局容器：強制固定左右留白 */
      .site-container {
        width: 100% !important;
        max-width: 100% !important;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        margin: 0 auto !important;
        padding-left: 2rem !important; /* 電腦版留白加大一點點，比較舒適 */
        padding-right: 2rem !important;
        box-sizing: border-box !important;
      }

      .site-container > main {
        flex: 1 0 auto;
        width: 100%;
      }

      @media (max-width: 768px) {
        .site-container {
          padding-left: 1rem !important; /* 手機版留白 */
          padding-right: 1rem !important;
        }
      }
    </style>
  </head>
  <body>
    <SmoothScroll />
    
    <div class="site-container">
      <Header />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
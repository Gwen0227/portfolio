---
import { getCollection } from "astro:content";
import Preloader from "../components/Preloader.astro";
import ProductGrid from "../components/ProductGrid.astro";
import ProductGridHeader from "../components/ProductGridHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const allProjects = await getCollection("projects");
const projectsTotal = allProjects.length;

const title = "Pei Jyuan Personal Portfolio";
---

<BaseLayout title={title}>
	<Preloader />

	<ProductGridHeader productsTotal={projectsTotal} />

	<ProductGrid projects={allProjects} />
</BaseLayout>

<script>
	function syncCategoryFromUrl() {
		const urlParams = new URLSearchParams(window.location.search);
		const categoryParam = urlParams.get('category')?.trim().toLowerCase();

		if (!categoryParam) return;

		// 給予一點點延遲，確保 ProductGridHeader 的 JS 元件已完全載入並綁定好點擊事件
		setTimeout(() => {
			// 抓取 ProductGridHeader 內所有的可點擊元素
			const allClickables = document.querySelectorAll('header *, nav *, [class*="header"] *, [class*="category"] *');
			let targetBtn: HTMLElement | null = null;

			allClickables.forEach((el) => {
				const text = el.textContent?.trim().toLowerCase();
				const dataCat = el.getAttribute('data-category')?.toLowerCase();

				if (categoryParam === 'all') {
					if (text === 'all' || dataCat === 'all') {
						targetBtn = el as HTMLElement;
					}
				} else {
					if (text === categoryParam || dataCat === categoryParam) {
						targetBtn = el as HTMLElement;
					}
				}
			});

			if (targetBtn) {
				(targetBtn as HTMLElement).click();
			}
		}, 50);
	}

	document.addEventListener('astro:page-load', syncCategoryFromUrl);
	// 如果沒有觸發 page-load，預備DOMContentLoaded
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', syncCategoryFromUrl);
	} else {
		syncCategoryFromUrl();
	}
</script>
---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductGridHeader from "../components/ProductGridHeader.astro";
import ProductCard from "../components/ProductCard.astro";

const allProjects = await getCollection("projects");
---

<BaseLayout title="Home">
  <ProductGridHeader 
    activeCategory="all" 
    productsTotal={allProjects.length} 
  />

  <section class="product-grid" id="product-grid">
    {allProjects.map((project) => (
      <div 
        class="card-item-wrapper" 
        data-card-category={(project.data.category || "Visual").toLowerCase()}
      >
        <ProductCard product={project} />
      </div>
    ))}
  </section>
</BaseLayout>

<script>
  function initCategoryFilter() {
    // 取得網址上的 category 參數 (預設為 all)
    const urlParams = new URLSearchParams(window.location.search);
    const rawCategory = urlParams.get("category") || "all";
    const currentCategory = rawCategory.trim().toLowerCase();

    // 1. 隱藏/顯示對應卡片
    const cards = document.querySelectorAll("[data-card-category]");
    let visibleCount = 0;

    cards.forEach((card) => {
      const cardCat = (card.getAttribute("data-card-category") || "").trim().toLowerCase();

      if (currentCategory === "all" || cardCat === currentCategory) {
        (card as HTMLElement).style.display = "";
        visibleCount++;
      } else {
        (card as HTMLElement).style.display = "none";
      }
    });

    // 2. 高亮 Header 分類按鈕
    const buttons = document.querySelectorAll(".categories a, .categories button");
    buttons.forEach((btn) => {
      const btnFilter = (btn.getAttribute("data-filter") || "").trim().toLowerCase();
      if (btnFilter === currentCategory) {
        btn.classList.add("active");
      } else {
        btn.classList.remove("active");
      }
    });

    // 3. 更新項目總數數字
    const countEl = document.querySelector(".count");
    if (countEl) {
      countEl.textContent = `${visibleCount} Projects`;
    }
  }

  // 🎯 關鍵：監聽所有 ClientRouter 轉場與網址變化
  document.addEventListener("astro:page-load", initCategoryFilter);
  document.addEventListener("astro:after-swap", initCategoryFilter);
  window.addEventListener("popstate", initCategoryFilter);

  // 點擊分類按鈕時立即延遲微秒觸發，確保 ClientRouter 已更新網址
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    if (target.closest(".categories a") || target.closest("#back-btn")) {
      setTimeout(initCategoryFilter, 50);
    }
  });

  // 首次載入直接執行
  initCategoryFilter();
</script>

<style>
  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
  }

  .card-item-wrapper {
    width: 100%;
  }
</style>
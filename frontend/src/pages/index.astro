---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductGridHeader from "../components/ProductGridHeader.astro";
import ProductCard from "../components/ProductCard.astro";

const allProjects = await getCollection("projects");
---

<BaseLayout title="Home">
	<ProductGridHeader 
		activeCategory="all" 
		productsTotal={allProjects.length} 
	/>

	<section class="product-grid" id="product-grid">
		{allProjects.map((project) => (
			<div 
				class="card-item-wrapper" 
				data-card-category={(project.data.category || "Visual").toLowerCase()}
			>
				<ProductCard product={project} />
			</div>
		))}
	</section>
</BaseLayout>

<script>
	function filterCategory(categoryName) {
		const targetCategory = (categoryName || "all").trim().toLowerCase();

		// 1. 用 CSS 自訂屬性控制隱藏與顯示，不干擾原生 CSS Grid 佈局
		const cards = document.querySelectorAll("[data-card-category]");
		let visibleCount = 0;

		cards.forEach((card) => {
			const cardCat = (card.getAttribute("data-card-category") || "").trim().toLowerCase();

			if (targetCategory === "all" || cardCat === targetCategory) {
				card.removeAttribute("data-hidden");
				visibleCount++;
			} else {
				card.setAttribute("data-hidden", "true");
			}
		});

		// 2. 高亮選中的分類按鈕
		const buttons = document.querySelectorAll(".categories a, .categories button");
		buttons.forEach((btn) => {
			const btnFilter = (btn.getAttribute("data-filter") || "").trim().toLowerCase();
			if (btnFilter === targetCategory) {
				btn.classList.add("active");
			} else {
				btn.classList.remove("active");
			}
		});

		// 3. 更新作品計數
		const countEl = document.querySelector(".count");
		if (countEl) {
			countEl.textContent = `${visibleCount} Projects`;
		}
	}

	function initFilterSystem() {
		// 優先讀取 sessionStorage 紀錄的分類
		const savedCategory = sessionStorage.getItem("activeCategory");
		const urlParams = new URLSearchParams(window.location.search);
		const currentCategory = savedCategory || urlParams.get("category") || "all";

		filterCategory(currentCategory);

		// 還原剛才點擊作品時的「捲軸高度」
		const savedScrollPos = sessionStorage.getItem("scrollPosition");
		if (savedScrollPos) {
			setTimeout(() => {
				window.scrollTo({
					top: parseInt(savedScrollPos, 10),
					behavior: "instant"
				});
				sessionStorage.removeItem("scrollPosition");
			}, 50);
		}

		// 分類按鈕點擊事件
		const categoryNav = document.querySelector(".categories");
		if (categoryNav) {
			categoryNav.addEventListener("click", (e) => {
				const targetLink = e.target.closest("[data-filter]");
				if (!targetLink) return;

				e.preventDefault();
				const selectedCat = targetLink.getAttribute("data-filter") || "all";

				sessionStorage.setItem("activeCategory", selectedCat);

				const newUrl = selectedCat === "all" ? "/" : `/?category=${selectedCat}`;
				window.history.pushState({ category: selectedCat }, "", newUrl);

				filterCategory(selectedCat);
			});
		}

		// 點擊作品卡片時，記錄目前的捲軸高度
		const projectLinks = document.querySelectorAll(".product-grid a");
		projectLinks.forEach((link) => {
			link.addEventListener("click", () => {
				sessionStorage.setItem("scrollPosition", window.scrollY.toString());
			});
		});
	}

	// 監聽歷史紀錄變更 (上一頁/下一頁)
	window.addEventListener("popstate", () => {
		const urlParams = new URLSearchParams(window.location.search);
		const cat = urlParams.get("category") || "all";
		sessionStorage.setItem("activeCategory", cat);
		filterCategory(cat);
	});

	initFilterSystem();
	document.addEventListener("astro:page-load", initFilterSystem);
</script>

<style>
	/* 🖥️ 電腦版與預設：視窗最大時一行 6 張圖 */
	.product-grid {
		display: grid;
		grid-template-columns: repeat(6, 1fr);
		gap: 1.5rem;
		margin-top: 2rem;
		margin-bottom: 4rem;
		width: 100%;
	}

	.card-item-wrapper {
		width: 100%;
	}

	/* 被過濾隱藏的卡片 */
	.card-item-wrapper[data-hidden="true"] {
		display: none !important;
	}

	/* 💻 平板螢幕 (1024px 以下)：一行 4 張圖 */
	@media (max-width: 1024px) {
		.product-grid {
			grid-template-columns: repeat(4, 1fr);
			gap: 1.2rem;
		}
	}

	/* 📱 手機版螢幕 (768px 以下)：強制保持一行 3 張圖 */
	@media (max-width: 768px) {
		.product-grid {
			grid-template-columns: repeat(3, 1fr) !important;
			gap: 0.5rem !important;
			margin-top: 1rem;
			margin-bottom: 3rem;
		}
	}
</style>
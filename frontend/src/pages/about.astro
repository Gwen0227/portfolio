---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "About | Chen-Pei Jyuan";
---

<BaseLayout title={title}>
	<section class="content">
		<h1>About</h1>

		<p class="intro">
			Hi, I'm <strong>Chen-Pei Jyuan</strong>, a Brand & Visual Designer
			based in Taiwan.
		</p>

		<p>
			I focus on creating brand identities, visual systems, packaging,
			editorial design and digital experiences that combine aesthetics with
			clear communication.
		</p>

		<div class="info">
			<div>
				<h2>Expertise</h2>

				<ul>
					<li>Brand Identity</li>
					<li>Visual Design</li>
					<li>Packaging Design</li>
					<li>Typography</li>
				</ul>
			</div>

			<div>
				<h2>Tools</h2>

				<ul>
					<li>Adobe Illustrator</li>
					<li>Adobe Photoshop</li>
					<li>Adobe InDesign</li>
					<li>Figma</li>
				</ul>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.content {
		max-width: 900px;
		margin: 4rem auto;
		padding: 0 1rem;
	}

	h1 {
		font-size: 3rem;
		margin-bottom: 2rem;
	}

	.intro {
		font-size: 1.25rem;
		margin-bottom: 1.5rem;
	}

	.info {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 4rem;
		margin-top: 4rem;
	}

	h2 {
		font-size: 1rem;
		margin-bottom: 1rem;
	}

	ul {
		list-style: none;
		padding: 0;
		margin: 0;
		line-height: 2;
	}

	@media (max-width:768px) {
		.info {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
	}
</style>
---
import { getCollection, render } from "astro:content";
// 修正這裡的路徑，確保能找到 src/layouts/Layout.astro
// 如果此檔案在 src/pages/，那就只要用 ../layouts/Layout.astro
import Layout from "../layouts/Layout.astro"; 

export async function getStaticPaths() {
    const projects = await getCollection("projects");
    return projects.map((project) => ({
        params: { slug: project.data.slug },
        props: { project },
    }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Layout title={project.data.title}>
    <main class="project-detail">
        <a href="/" class="back-link">← 回首頁</a>
        
        <header>
            <h1>{project.data.title}</h1>
        </header>

        <img src={project.data.cover} alt={project.data.title} class="protected-img" />

        <article class="prose">
            <Content />
        </article>
    </main>
</Layout>

<style>
    .project-detail {
        max-width: 800px;
        margin: 4rem auto;
        padding: 0 1rem;
    }

    .back-link {
        display: inline-block;
        margin-bottom: 2rem;
        color: #000;
        text-decoration: none;
    }

    .protected-img {
        width: 100%;
        border-radius: 8px;
        margin-bottom: 2rem;
        /* 加入我們剛剛設定的防護效果 */
        filter: blur(0.6px);
        transition: filter 0.3s ease;
        user-select: none;
        -webkit-user-drag: none;
    }
    
    .protected-img:hover {
        filter: blur(0);
    }

    /* 讓 Markdown 的內容美觀 */
    .prose {
        line-height: 1.6;
        color: #333;
    }
    .prose h2 { margin-top: 2rem; font-size: 1.5rem; }
    .prose p { margin-bottom: 1rem; }
</style>
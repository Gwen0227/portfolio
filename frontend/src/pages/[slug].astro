---
import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductGridHeader from "../components/ProductGridHeader.astro";

export async function getStaticPaths() {
	const projects = await getCollection("projects");
	return projects.map((project) => ({
		params: { slug: project.data.slug },
		props: { project },
	}));
}

const { project } = Astro.props;

if (!project) {
	throw new Error("Project not found");
}

const { Content } = await render(project);

// 🎯 取得所有專案列表與數量
const allProjects = (await getCollection("projects")) || [];
const productsTotal = allProjects.length;

// 🎯 取得該作品的分類，若無則預設為 "all"
const activeCategory = project.data?.category || "all";
---

<BaseLayout title={project.data.title}>
	<ProductGridHeader 
		activeCategory={activeCategory} 
		productsTotal={productsTotal} 
	/>

	<article class="project-detail">
		<header class="project-header">
			<h1 class="main-title">{project.data.title}</h1>
		</header>

		{project.data.cover && (
			<figure class="featured-image">
				<img 
					src={project.data.cover} 
					alt={project.data.title} 
					class="protected-img" 
				/>
			</figure>
		)}

		<div class="prose">
			<Content />
		</div>
	</article>
</BaseLayout>

<style>
	/* 🎯 主容器：100% 貼合外層 Layout 的左右留白邊界 */
	.project-detail {
		width: 100%;
		margin: 1.5rem 0 6rem;
		box-sizing: border-box;
	}

	.project-header {
		margin-bottom: 1.5rem;
	}

	/* 主標題 (粗體大字) */
	.main-title {
		font-size: 1.5rem;
		font-weight: 700;
		color: #000000;
		margin: 0;
		line-height: 1.3;
	}

	/* 封面大圖樣式 */
	.featured-image {
		width: 100%;
		margin: 0 0 2.5rem 0;
	}

	/* 🎯 圖片 AI 防護與樣式 */
	.protected-img, 
	.prose img {
		width: 100%;
		height: auto;
		display: block;
		border-radius: 4px;
		user-select: none;
		-webkit-user-drag: none;
		
		/* 防盜防擷取微模糊效果 */
		filter: blur(0.6px);
		transition: filter 0.3s ease;
	}

	.protected-img:hover, 
	.prose img:hover {
		filter: blur(0);
	}

	/* 🎯 Markdown 內文豐富排版 (.prose) */
	.prose {
		width: 100%;
		color: #222222;
		font-size: 0.95rem;
		line-height: 1.85;
	}

	/* 中標題 (h2) */
	.prose :global(h2) {
		font-size: 1.2rem;
		font-weight: 700;
		color: #000000;
		margin-top: 3rem;
		margin-bottom: 1.2rem;
		line-height: 1.4;
	}

	/* 小標題 (h3) */
	.prose :global(h3) {
		font-size: 1.05rem;
		font-weight: 700;
		color: #000000;
		margin-top: 2rem;
		margin-bottom: 1rem;
	}

	/* 段落內文 (兩端對齊) */
	.prose :global(p) {
		margin-bottom: 1.5rem;
		text-align: justify;
		word-break: break-word;
	}

	/* Markdown 內的圖片與圖說 (<figure> & <figcaption>) */
	.prose :global(figure) {
		width: 100%;
		margin: 2.5rem 0;
	}

	.prose :global(figcaption) {
		margin-top: 0.6rem;
		font-size: 0.85rem;
		color: #888888;
		line-height: 1.5;
	}

	/* 清單樣式 */
	.prose :global(ul), 
	.prose :global(ol) {
		margin-left: 1.2rem;
		margin-bottom: 1.5rem;
	}

	.prose :global(li) {
		margin-bottom: 0.4rem;
	}

	@media (max-width: 768px) {
		.main-title {
			font-size: 1.3rem;
		}

		.prose :global(h2) {
			font-size: 1.1rem;
			margin-top: 2rem;
		}
	}
</style>
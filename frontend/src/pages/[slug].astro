---
import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectFilter from "../components/ProjectFilter.astro";

export async function getStaticPaths() {
	const projects = await getCollection("projects");
	return projects.map((project) => ({
		params: { slug: project.data.slug },
		props: { project },
	}));
}

const { project } = Astro.props;

// 1. 安全防護：確認 project 存在
if (!project) {
	throw new Error("Project not found");
}

const { Content } = await render(project);

// 2. 安全防護：取得所有專案列表與數量，並處理空值
const allProjects = (await getCollection("projects")) || [];
const productsTotal = allProjects.length;

// 3. 安全防護：確保 activeCategory 絕對不會是 undefined
const activeCategory = project.data?.category || "all";
---

<BaseLayout title={project.data.title}>
	<ProjectFilter 
		activeCategory={activeCategory} 
		productsTotal={productsTotal} 
	/>

	<main class="project-detail">
		<header>
			<h1>{project.data.title}</h1>
		</header>

		{project.data.cover && (
			<img src={project.data.cover} alt={project.data.title} class="protected-img" />
		)}

		<article class="prose">
			<Content />
		</article>
	</main>
</BaseLayout>

<style>
	.project-detail {
		max-width: 800px;
		margin: 2rem auto 4rem auto;
		padding: 0 1rem;
	}

	.protected-img {
		width: 100%;
		border-radius: 8px;
		margin-bottom: 2rem;
		filter: blur(0.6px);
		transition: filter 0.3s ease;
		user-select: none;
		-webkit-user-drag: none;
	}

	.protected-img:hover {
		filter: blur(0);
	}

	.prose {
		line-height: 1.7;
		color: #333333;
	}
	.prose h2 { margin-top: 2rem; font-size: 1.5rem; }
	.prose p { margin-bottom: 1.2rem; }
	.prose ul { margin-left: 1.5rem; margin-bottom: 1rem; }
</style>
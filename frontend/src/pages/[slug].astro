---
import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductGridHeader from "../../components/ProductGridHeader.astro";

export async function getStaticPaths() {
	const projects = await getCollection("projects");
	return projects.map((project) => ({
		params: { slug: project.data.slug },
		props: { project },
	}));
}

const { project } = Astro.props;

if (!project) {
	throw new Error("Project not found");
}

const { Content } = await render(project);

const allProjects = (await getCollection("projects")) || [];
const productsTotal = allProjects.length;

const defaultCategory = (project.data?.category || "all").toLowerCase();
---

<BaseLayout title={project.data.title}>
	<ProductGridHeader 
		activeCategory={defaultCategory} 
		productsTotal={productsTotal} 
	/>

	<article class="project-detail">
		<a 
			href="/" 
			id="back-btn" 
			class="back-btn" 
			aria-label="Back to previous page"
		>
			<svg 
				width="20" 
				height="20" 
				viewBox="0 0 24 24" 
				fill="none" 
				stroke="currentColor" 
				stroke-width="2" 
				stroke-linecap="round" 
				stroke-linejoin="round"
			>
				<line x1="19" y1="12" x2="5" y2="12"></line>
				<polyline points="12 19 5 12 12 5"></polyline>
			</svg>
		</a>

		<header class="project-header">
			<h1 class="main-title">{project.data.title}</h1>
		</header>

		{project.data.cover && (
			<figure class="featured-image">
				<img 
					src={project.data.cover} 
					alt={project.data.title} 
					class="protected-img" 
				/>
			</figure>
		)}

		<div class="prose">
			<Content />
		</div>
	</article>
</BaseLayout>

<script>
	function setupBackBtn() {
		const btn = document.getElementById('back-btn');
		if (!btn) return;

		btn.addEventListener('click', (e) => {
			if (document.referrer && document.referrer.includes(window.location.host)) {
				e.preventDefault();
				history.back();
			}
		});
	}

	setupBackBtn();
	document.addEventListener('astro:page-load', setupBackBtn);
</script>

<style>
	.project-detail {
		width: 100%;
		margin: 1.5rem 0 6rem;
		box-sizing: border-box;
	}

	.back-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		color: #222222;
		background: transparent;
		border-radius: 50%;
		text-decoration: none;
		margin-bottom: 1.2rem;
		transition: all 0.2s ease;
		cursor: pointer;
	}

	.back-btn:hover {
		color: #000000;
		background-color: #f2f2f2;
		transform: translateX(-4px);
	}

	.back-btn svg {
		width: 20px;
		height: 20px;
		stroke: currentColor;
	}

	.project-header {
		margin-bottom: 1.5rem;
	}

	.main-title {
		font-size: 3.2rem !important;
		font-weight: 500 !important;
		color: #000000 !important;
		margin: 0 !important;
		line-height: 1.2 !important;
		letter-spacing: -0.02em !important;
	}

	.featured-image {
		width: 100%;
		aspect-ratio: 16 / 9;
		margin: 0 0 2.5rem 0;
		overflow: hidden;
		background: #f9f9f9;
		border-radius: 4px;
	}

	.featured-image .protected-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		user-select: none;
		-webkit-user-drag: none;
		filter: blur(0.6px);
		transition: filter 0.3s ease;
		margin-bottom: 0;
	}

	.prose :global(img) {
		width: 100%;
		height: auto;
		display: block;
		border-radius: 4px;
		user-select: none;
		-webkit-user-drag: none;
		filter: blur(0.6px);
		transition: filter 0.3s ease;
		margin-bottom: 0.5rem;
	}

	.protected-img:hover, 
	.prose :global(img:hover) {
		filter: blur(0);
	}

	.prose {
		width: 100%;
		color: #222222;
		font-size: 0.95rem;
		line-height: 1.85;
	}

	.prose :global(h1) {
		font-size: 2.5rem !important;
		font-weight: 700 !important;
		color: #000000 !important;
		margin-top: 3.5rem !important;
		margin-bottom: 1rem !important;
		line-height: 1.25 !important;
	}

	.prose :global(h2) {
		font-size: 1.6rem !important;
		font-weight: 700 !important;
		color: #000000 !important;
		margin-top: 3rem !important;
		margin-bottom: 0.75rem !important;
		line-height: 1.35 !important;
	}

	.prose :global(h3) {
		font-size: 1.2rem !important;
		font-weight: 700 !important;
		color: #000000 !important;
		margin-top: 2rem !important;
		margin-bottom: 0.75rem !important;
	}

	.prose :global(hr.slash) {
		border: none;
		outline: none;
		width: 40px;
		height: 0.8px;
		background-color: #000000;
		margin: 1.5rem 0 2.2rem 0;
		transform: rotate(-25deg);
		transform-origin: left center;
	}

	.prose :global(p) {
		margin-bottom: 1.5rem;
		text-align: justify;
		word-break: break-word;
	}

	.prose :global(figcaption),
	.prose :global(p img + em),
	.prose :global(p img + br + em),
	.prose :global(p img + span) {
		display: block;
		margin-top: 0.5rem;
		margin-bottom: 2.2rem;
		font-style: normal;
		font-size: 0.68rem !important;
		color: #888888 !important;
		line-height: 1.5;
		letter-spacing: 0.02em;
	}

	.prose :global(ul), 
	.prose :global(ol) {
		margin-left: 1.2rem;
		margin-bottom: 1.5rem;
	}

	.prose :global(li) {
		margin-bottom: 0.4rem;
	}

	@media (max-width: 768px) {
		.main-title {
			font-size: 2rem !important;
		}

		.prose :global(h1) {
			font-size: 1.8rem !important;
		}

		.prose :global(h2) {
			font-size: 1.3rem !important;
			margin-top: 2rem !important;
		}
	}
</style>
---
import { getCollection, render } from "astro:content";

// 1. 告訴 Astro 有哪些頁面需要生成
export async function getStaticPaths() {
    const projects = await getCollection("projects");
    return projects.map((project) => ({
        params: { slug: project.data.slug },
        props: { project },
    }));
}

// 2. 取得該作品的資料與內容
const { project } = Astro.props;
const { Content } = await render(project);
---

<html lang="zh-Hant">
    <head>
        <title>{project.data.title} | My Portfolio</title>
    </head>
    <body>
        <main style="max-width: 800px; margin: 4rem auto; padding: 0 1rem;">
            <a href="/">← 回首頁</a>
            
            <h1>{project.data.title}</h1>
            <p>年份：{project.data.year} | 分類：{project.data.category}</p>
            
            <img 
                src={project.data.cover} 
                alt={project.data.title} 
                style="width: 100%; border-radius: 8px; margin: 1rem 0;" 
            />

            <article class="prose">
                <Content />
            </article>

            <div style="margin-top: 2rem;">
                {project.data.github && <a href={project.data.github} target="_blank">GitHub</a>}
                {project.data.demo && <a href={project.data.demo} target="_blank" style="margin-left: 1rem;">Live Demo</a>}
            </div>
        </main>
    </body>
</html>

<style>
    /* 簡單的排版風格，你可以根據你的 CSS 需求調整 */
    .prose {
        line-height: 1.6;
        color: #333;
    }
    h1 { font-size: 2.5rem; margin-bottom: 0.5rem; }
</style>